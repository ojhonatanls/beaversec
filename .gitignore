# BeaverSec - repository ignore rules

# Byte-compiled / cache
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/
.Python

# Distribution / build
build/
dist/
*.egg-info/

# Python artifacts
*.pyc
*.pyo
*.pyd

# Logs and reports
*.log
report_*.json
report_*.html

# Data directory (scan results, temporary files)
data/

# Test and type-check caches
.pytest_cache/
.mypy_cache/

# IDEs
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db
