# BeaverSec Configuration - Environment Variables
# Copy this file to .env and fill in your values

# API Keys (required for some modules)
SHODAN_API_KEY=
NVD_API_KEY=
SECURITYTRAILS_API_KEY=

# Network Configuration
BEAVERSCAN_THREADS=10
BEAVERSCAN_TIMEOUT=5.0
BEAVERSCAN_RATE_LIMIT=100
BEAVERSCAN_VERBOSE=false

# Proxy Configuration
PROXY_URL=
PROXY_USERNAME=
PROXY_PASSWORD=
USE_TOR=false
TOR_PROXY=socks5://127.0.0.1:9050

# Security Settings
LOG_LEVEL=INFO
AUDIT_LOG_ENABLED=true
MAX_RESULTS=10000